# =============================================================================
# Agent Memory System - systemd 服务配置
# 安装: sudo cp agent-memory.service /etc/systemd/system/
# 启用: sudo systemctl enable agent-memory
# 启动: sudo systemctl start agent-memory
# =============================================================================

[Unit]
Description=Agent Memory System - 企业级Agent记忆中台
Documentation=https://github.com/your-org/agent-memory-system
After=network.target docker.service
Wants=docker.service

# 启动超时限制
TimeoutStartSec=60
TimeoutStopSec=30

[Service]
Type=simple
User=agent-memory
Group=agent-memory

# 工作目录和JAR路径
WorkingDirectory=/opt/agent-memory-system
ExecStart=/usr/bin/java \
    -server \
    -Xms512m \
    -Xmx1g \
    -XX:+UseG1GC \
    -XX:MaxGCPauseMillis=200 \
    -XX:+HeapDumpOnOutOfMemoryError \
    -XX:HeapDumpPath=/opt/agent-memory-system/logs/heapdump.hprof \
    -Djava.security.egd=file:/dev/./urandom \
    -jar /opt/agent-memory-system/agent-memory-system-1.0.0.jar

# 进程停止信号
KillMode=mixed
KillSignal=SIGTERM

# 重启策略
Restart=on-failure
RestartSec=10
StartLimitInterval=300
StartLimitBurst=5

# 环境变量（按需修改）
Environment=SPRING_PRODUCTION=true
Environment=JAVA_OPTS=-XX:+UseG1GC

# 日志输出到 journal
StandardOutput=journal
StandardError=journal
SyslogIdentifier=agent-memory

# 安全加固
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/opt/agent-memory-system/logs
PrivateTmp=true
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectControlGroups=true

# 资源限制
MemoryMax=1G
MemoryHigh=800M
CPUQuota=80%
LimitNOFILE=65536
LimitNPROC=4096

# OOM保护
OOMScoreAdjust=-500

[Install]
WantedBy=multi-user.target
